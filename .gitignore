data/*
!data/news/
# forward-collection OI/funding HL: dati NON rigenerabili, vanno versionati
!data/hl_oi/
# forward-collection liquidazioni 1h Coinalyze: accumula oltre la retention, NON rigenerabile
!data/coinalyze_1h/
# cache forecast Kronos: versionata per il cloud (rigenerata dal workflow kronos-precompute)
!data/kronos/
# cache rank cross-sectional xsection_momentum: versionata per il cloud (workflow xsection-precompute)
!data/xsection/
# cache regime HMM: versionata per il cloud (regenerabile via precompute_hmm.py, nessun workflow CI dedicato)
!data/hmm/
.venv/
__pycache__/
.env
.firecrawl/
logs/
.claude/

# Kronos repo vendored (modello, non versionare)
.kronos/
paper/executor.jsonl

# skill bundle locali (dev tooling: impeccable, review-animations) — non runtime
.agents/
.github/skills/
skills-lock.json

# layer LLM: tracing e cache applicativo sono dati runtime (regenerati ogni run), non versionarli
paper/llm_calls.jsonl
paper/llm_cache/

# backup automatici della pipeline (es. decisions.jsonl.bak.<ts>)
paper/*.bak.*

# config CLI Supabase temporanea (project-ref, versioni) — non versionare
supabase/.temp/

# tooling temporaneo di live-render / screenshot del design skill (prefisso _)
scripts/_render_*.js
scripts/_shot_*.png
